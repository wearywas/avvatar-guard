{
  "manifest_version": 3,
  "name": "Avvatar Guard",
  "version": "0.2.0",
  "description": "Visual fingerprints for every domain. Spot lookalike phishing sites at a glance.",
  "permissions": ["tabs", "storage", "activeTab"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Avvatar Guard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  }
}
